{
  "name": "@ch8r/widget",
  "private": true,
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i src/styles/base.css -o src/styles/widget.css --minify",
    "build:dev": "npm run build:css && vite build && cp dist/widget.js ../frontend/public/widget.js",
    "build": "npm run build:css && vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@preact/signals": "^1.3.2",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "preact": "^10.25.4"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.4",
    "@tailwindcss/forms": "^0.5.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "fast-check": "^3.23.2",
    "jsdom": "^26.1.0",
    "tailwindcss": "^3.4.17",
    "terser": "^5.39.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
