#!/bin/bash

# GitHub API - Get Pull Request Files
# Usage: ./get_pull_request_files.sh owner repo pr_number [page] [per_page]

OWNER=${1:-"owner"}
REPO=${2:-"repo"}
PR_NUMBER=${3:-"1"}
PAGE=${4:-"1"}
PER_PAGE=${5:-"100"}
TOKEN=${GITHUB_TOKEN:-"your_github_token_here"}

curl -X GET \
  -H "Authorization: Bearer ${TOKEN}" \
  -H "Accept: application/vnd.github+json" \
  -H "X-GitHub-Api-Version: 2022-11-28" \
  -H "User-Agent: Ch8r-GitHub-Ingestion/1.0" \
  "https://api.github.com/repos/${OWNER}/${REPO}/pulls/${PR_NUMBER}/files?page=${PAGE}&per_page=${PER_PAGE}"
